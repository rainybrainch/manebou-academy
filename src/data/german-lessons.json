                "usage": "会話での日付表現"
              }
            ]
          }
        ]
      },
      "practiceQuestions": [
        {
          "id": "de-002-q1",
          "type": "fill-blank",
          "question": "「5」をドイツ語で言ってください。",
          "answer": "fünf"
        },
        {
          "id": "de-002-q2",
