          },
          {
            "title": "日付の表現",
            "phrases": [
              {
                "german": "Der 3. März 2024",
                "romaji": "DAIR DRAY. MÄRTS TSVAY-tousent FEER-unt-tsvahn-tsikh",
                "japanese": "2024年3月3日",
                "usage": "正式な日付表現。序数と月を組み合わせる"
              },
              {
                "german": "Heute ist Montag, den 15. Januar.",
                "romaji": "HOY-te ist MON-tag DEN FOONF-tsan YAH-nu-ar",
