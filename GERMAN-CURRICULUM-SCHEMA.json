    "germanLanguageFeatures": {
      "caseSystem": {
        "description": "ドイツ語の4つの格システム",
        "cases": {
          "nominativ": {
            "name": "主格",
            "function": "主語、述語名詞",
            "question": "wer? was?（誰が？何が？）"
          },
          "akkusativ": {
            "name": "対格",
            "function": "直接目的語、時間表現",
            "question": "wen? was?（誰を？何を？）"
          },
          "dativ": {
            "name": "与格",
            "function": "間接目的語、場所",
            "question": "wem?（誰に？どこに？）"
          },
          "genitiv": {
            "name": "属格",
            "function": "所有、属性関係",
            "question": "wessen?（誰の？）"
          }
        },
        "coverage": "A1 から B2 まで段階的に習得"
      },
